# Database (Supabase)
# Get from: https://app.supabase.com/project/_/settings/database
# Format: postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres"

# Blockchain
RPC_URL="https://sepolia.base.org"
CHAIN_ID=84532
ESCROW_ADDRESS="0x..."
PRIVATE_KEY="0x..."  # For signing proofs (NOT for transactions)

# BankrBot Integration
BANKR_API_KEY="bk_..."
BANKR_API_URL="https://api.bankr.bot"

# IPFS (Pinata)
PINATA_JWT="..."
PINATA_GATEWAY="https://gateway.pinata.cloud"

# Server
PORT=3000
NODE_ENV="development"

# Identity Verification
IDENTITY_VERIFIER_ADDRESS="0x..."
COURT_ACCESS_ADDRESS="0x251026B235Ab65fBC28674984e43F6AC9cF4d79A"  # SignetID on Base Sepolia

# Optional: Kairen Integration
KAIREN_API_URL=""
KAIREN_API_KEY=""

# x402n bridge (DealRail mock mode default true)
X402N_BASE_URL="http://localhost:8080/api/v1"
X402N_API_KEY=""
X402N_MOCK_MODE="true"
X402N_CATEGORY_ID=""

# Uniswap integration (Base Mainnet)
BASE_MAINNET_RPC="https://mainnet.base.org"
UNISWAP_QUOTER_V2_BASE="0x3d4e44Eb1374240CE5F1B871ab261CD16335B76a"
UNISWAP_SWAP_ROUTER_02_BASE="0x2626664c2603336E57B271c5C0b26F421741e481"
UNISWAP_UNIVERSAL_ROUTER_BASE="0x3fC91A3afd70395Cd496C647d5a6CC9D4B2b7FAD"

# Locus MCP bridge
LOCUS_MCP_URL="https://mcp.paywithlocus.com/mcp"
LOCUS_API_KEY=""
LOCUS_MOCK_MODE="true"
LOCUS_SEND_USDC_TOOL="send_usdc"

# Neutral discovery adapters
DISCOVERY_X402N_ENABLED="true"
DISCOVERY_VIRTUALS_ENABLED="false"
DISCOVERY_NEAR_ENABLED="false"
DISCOVERY_VIRTUALS_SERVICES_URL=""
DISCOVERY_NEAR_SERVICES_URL=""
DISCOVERY_TIMEOUT_MS="3500"

# ERC-8004 identity/reputation source
ERC8004_IDENTITY_REGISTRY="0x8004A169FB4a3325136EB29fA0ceB6D2e539a432"
ERC8004_REPUTATION_REGISTRY="0x8004BAa17C55a88189AE136b182e5fdA19dE9b63"

# Celo Sepolia (active Celo testnet)
CELO_SEPOLIA_RPC="https://forno.celo-sepolia.celo-testnet.org"
CELO_SEPOLIA_STABLE_TOKEN="0x01C5C0122039549AD1493B8220cABEdD739BC44E"
ESCROW_RAIL_CELO_SEPOLIA=""
ESCROW_RAIL_ERC20_CELO_SEPOLIA=""
DEALRAIL_HOOK_CELO_SEPOLIA=""
ERC8004_VERIFIER_CELO_SEPOLIA=""
